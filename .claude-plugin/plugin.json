{
  "name": "design-loop",
  "description": "Autonomous visual iteration loop for frontend UI/UX. Screenshots your page, scores it against 8 design criteria, fixes issues, repeats until polished.",
  "version": "1.3.0",
  "author": {
    "name": "tonymfer",
    "email": "tony.base.eth@gmail.com"
  },
  "homepage": "https://github.com/tonymfer/design-loop",
