  "license": "MIT",
  "keywords": ["design", "ui", "ux", "visual-polish", "screenshots", "playwright", "iteration", "ralph-loop", "next.js", "react", "tailwind", "ssr", "framework-detection"],
  "dependencies": {
    "plugins": ["ralph-loop"],
    "mcpServers": {
      "playwright": {
        "command": "npx",
        "args": ["-y", "@playwright/mcp@latest"]
      }
    }
  }
